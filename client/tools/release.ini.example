# ftp-sync settings for RELEASE uploads.
# Copy to release.ini and fill in real values. release.ini is gitignored (holds the FTP password).
# This file is passed straight to ftp-sync; the [APP] section is ignored by the tool and read by
# the upload bats.
#
# Note: values are parsed by Python configparser. A literal percent sign in any value (e.g. in a
# password) must be written as %% .

[FTP]
FTP_HOST=ai.xida.de
FTP_USER=your_user
FTP_PASS=your_password
# Account is chrooted to the apps dir, so the FTP root is the target.
FTP_DIRECTORY=/
DIRECTION=up
# Keep existing remote files (older versioned APKs) instead of mirror-deleting them.
NO_DELETE=true

[APP]
# Public link base where APKs are served from.
APK_LINK_DIR=https://ai.xida.de/api/v11/apps/com.darusc.mousedroid
# Path to the ftp-sync tool checkout.
FTPSYNC_DIR=D:\GIT\BenjaminKobjolke\ftp-sync
